% --- Code listings ---
\usepackage{listings}
\lstset{
  backgroundcolor=\color{codebg},
  frame=single,
  rulecolor=\color{codeframe},
  basicstyle=\ttfamily\small,
  keywordstyle=\bfseries,
  commentstyle=\color{gray}\itshape,
  stringstyle=\color{black},
  breaklines=true,
  breakatwhitespace=true,
  tabsize=4,
  showstringspaces=false,
  aboveskip=1em,
  belowskip=1em,
  xleftmargin=1em,
  xrightmargin=1em,
  numbers=none,
}

