\titleformat{\section}
  {\Large\bfseries}
  {\thesection.}{0.5em}{}
\titleformat{\subsection}
  {\large\bfseries}
  {\thesubsection}{0.5em}{}
\titleformat{\subsubsection}
  {\normalsize\bfseries}
  {\thesubsubsection}{0.5em}{}

\pagestyle{fancy}
