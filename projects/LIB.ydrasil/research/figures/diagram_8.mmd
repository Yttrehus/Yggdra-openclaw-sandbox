graph TD
    subgraph "Hierarchical (Parent → Child)"
        S1[Supervisor] --> W1[Worker A]
        S1 --> W2[Worker B]
        W1 --> S1
        W2 --> S1
    end

    subgraph "Peer-to-Peer (Group Chat)"
        P1[Agent A] <--> P2[Agent B]
        P2 <--> P3[Agent C]
        P1 <--> P3
    end

    subgraph "Shared State"
        SS[Shared State Object]
        A1[Agent A] --> SS
        A2[Agent B] --> SS
        SS --> A1
        SS --> A2
    end

    subgraph "Sequential Handoff"
        H1[Agent A] --> H2[Agent B] --> H3[Agent C]
    end